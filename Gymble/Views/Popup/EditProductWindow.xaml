<Window x:Class="Gymble.Views.Popup.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gymble.Views.Popup"
        xmlns:converter="clr-namespace:Gymble.Converter"
        xmlns:vms="clr-namespace:Gymble.ViewModels.Popup"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="EditProductWindow" Height="Auto" Width="400" ResizeMode="NoResize"
        Style="{StaticResource PopupWindowStyle}" WindowStartupLocation="CenterScreen">
    <Border BorderBrush="{StaticResource ApplicationBorderColor}" BorderThickness="1" 
            CornerRadius="15" Background="{StaticResource ApplicationBgColor}"
            VerticalAlignment="Top">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Border Background="{StaticResource TitleBarBgColor}"
                    BorderBrush="{StaticResource DefaultBorderBrushColor}"
                    BorderThickness="0 0 0 1">
                <Border.Clip>
                    <MultiBinding Converter="{StaticResource TopRoundRectClipConverter}"
                      ConverterParameter="15">
                        <Binding RelativeSource="{RelativeSource Self}" Path="ActualWidth"/>
                        <Binding RelativeSource="{RelativeSource Self}" Path="ActualHeight"/>
                    </MultiBinding>
                </Border.Clip>
                <Grid>
                    <TextBlock Text="상품 수정" Margin="20 0"
                               Style="{StaticResource TitleTextBlockStyle}"
                               FontSize="20"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="X" Style="{StaticResource WIndowChromeButtonStyle}"
                                Foreground="Black" FontSize="18" FontWeight="Bold"
                                HorizontalAlignment="Right"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20 15 20 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="상품명" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <TextBox Grid.Column="1" 
                 Text="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AddMemberWindowTextBoxStyle}"/>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="상품코드" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <CheckBox Content="자동 생성" 
                  Grid.Column="1" Margin="0 0 10 0"
                  Foreground="Black" FontWeight="Bold" FontSize="14"
                  Style="{StaticResource MaterialDesignUserForegroundCheckBox}"
                  IsChecked="{Binding IsAutoCode}"/>
                    <TextBox Grid.Column="2" 
                 Text="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AddMemberWindowTextBoxStyle}"
                 IsReadOnly="{Binding IsAutoCode}"/>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="상품 종류" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Height="37"
                  Style="{StaticResource ComboBoxStyle}"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}, ConverterParameter=ProductCategory}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="기간/횟수" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Height="37"
                    HorizontalAlignment="Center">
                        <RadioButton Content="기간(일)" GroupName="usageType" Tag="Period"
                         Foreground="Black" FontWeight="Bold" FontSize="14"
                         Width="110" Height="37" Margin="0 0 25 0"
                         Style="{StaticResource MaterialDesignChoiceChipPrimaryOutlineRadioButton}"
                         IsChecked="{Binding SelectedUsageType, Converter={StaticResource TagMatchConverter}, ConverterParameter=Period, Mode=TwoWay}"/>
                        <RadioButton Content="횟수" GroupName="usageType" Tag="Count"
                         Foreground="Black" FontWeight="Bold" FontSize="14"
                         Width="110" Height="37" Margin="0"
                         Style="{StaticResource MaterialDesignChoiceChipPrimaryOutlineRadioButton}"
                         IsChecked="{Binding SelectedUsageType, Converter={StaticResource TagMatchConverter}, ConverterParameter=Count, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <TextBox Margin="110 10 0 0" Height="37"
                 Text="{Binding UsageValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AddMemberWindowTextBoxStyle}"/>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="가격(₩)" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <TextBox Grid.Column="1" Height="37"
                 Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource AddMemberWindowTextBoxStyle}"/>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="시작기준" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Height="37"
                  Style="{StaticResource ComboBoxStyle}"
                  ItemsSource="{Binding StartTypes}"
                  SelectedItem="{Binding SelectedStartType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="상태" 
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Height="37"
                    HorizontalAlignment="Center">
                        <RadioButton Content="판매중" GroupName="status" Tag="OnSale"
                         Foreground="Black" FontWeight="Bold" FontSize="14"
                         Width="110" Height="37" Margin="0 0 25 0"
                         Style="{StaticResource MaterialDesignChoiceChipPrimaryOutlineRadioButton}"
                         IsChecked="{Binding SelectedStatus, Converter={StaticResource TagMatchConverter}, ConverterParameter=OnSale, Mode=TwoWay}"/>
                        <RadioButton Content="판매중지" GroupName="status" Tag="Stopped"
                         Foreground="Black" FontWeight="Bold" FontSize="14"
                         Width="110" Height="37" Margin="0"
                         Style="{StaticResource MaterialDesignChoiceChipPrimaryOutlineRadioButton}"
                         IsChecked="{Binding SelectedStatus, Converter={StaticResource TagMatchConverter}, ConverterParameter=Stopped, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Content="자주 쓰는 상품으로 등록" 
              Height="37" Margin="0 10 0 0"
              Foreground="Black" FontWeight="Bold" FontSize="14"
              Style="{StaticResource MaterialDesignUserForegroundCheckBox}"
              IsChecked="{Binding IsFavorite, Mode=TwoWay}"/>

                <Separator Margin="0 10"
               BorderThickness="1" 
               BorderBrush="{StaticResource SeperatorBorderBrushColor}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="비고" VerticalAlignment="Center"
                   Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                    <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 Style="{StaticResource AddMemberWindowTextBoxStyle}"
                 Grid.Column="1" Height="37"/>
                </Grid>

                <Separator Margin="0 10 0 0"
               BorderThickness="1" 
               BorderBrush="{StaticResource SeperatorBorderBrushColor}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20 0"
            HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="취소" Margin="6 0"
            Style="{StaticResource AddMemberWindowButton}"
            BorderThickness="1" Background="#FAFAFA"
            Foreground="#202020"
            Command="{Binding CloseCommand}" Cursor="Hand"/>
                <Button Content="추가" Style="{StaticResource AddMemberWindowButton}"
            Command="{Binding AddCommand}" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
