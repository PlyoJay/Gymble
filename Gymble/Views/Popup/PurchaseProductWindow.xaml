<Window x:Class="Gymble.Views.Popup.PurchaseProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gymble.Views.Popup"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        xmlns:common="clr-namespace:Gymble.Views.Common"
        Title="PurchaseProductWindow" Height="555" Width="750"
        Style="{StaticResource PopupWindowStyle}" WindowStartupLocation="CenterScreen">
    <common:PopupFrameControl TitleText="이용권 등록">
        <common:PopupFrameControl.BodyContent>
            <StackPanel>
                <ContentControl Template="{StaticResource DefaultCardTemplate}"
                                Height="80">
                    <StackPanel Margin="15 0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0">
                            <TextBlock Style="{StaticResource HeaderKeyTextBlockStyle}"
                                       Text="{Binding TargetMember.Name}"/>
                            <TextBlock Style="{StaticResource ContentDataTextBlockStyle}" Margin="10 0">
                                (
                                <Run Text="{Binding TargetMember.PhoneNumber, Converter={StaticResource PhoneNumberConverter}}"/>
                                )
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                            <TextBlock Style="{StaticResource HeaderKeyTextBlockStyle}"
                                       Text="현재 이용권:"/>
                            <ContentControl Template="{StaticResource ChipTemplate}" 
                                            Background="#EFEFEF"
                                            Width="60" Height="25" Margin="10 0"
                                            Content="없음"/>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>
                <Grid Margin="0 20" Height="295">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="440"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="230"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                                   Text="상품" VerticalAlignment="Center"
                                   Height="30" Margin="0 0 0 10"/>

                        <TabControl Height="155"
                                    Style="{StaticResource GymbleTabControlStyle}"
                                    AlternationCount="1000000">
                            <TabItem Header="헬스권"
                                     Style="{StaticResource GymbleTabItemStyle}"
                                     MinWidth="87.6">
                                <Grid Margin="15 15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="헬스권:" Foreground="Black"
                                               Style="{StaticResource HeaderKeyTextBlockStyle}"/>
                                    <TextBlock Grid.Row="1" Text="시작 날짜:" Foreground="Black"
                                               Style="{StaticResource HeaderKeyTextBlockStyle}"/>

                                    <ComboBox Grid.Column="1" Height="35"
                                              Style="{StaticResource ComboBoxStyle}">
                                        
                                    </ComboBox>

                                    <DatePicker Grid.Row="1" Grid.Column="1"
                                                Height="35"
                                                md:HintAssist.Hint="Pick Date"
                                                Style="{StaticResource CustomDatePickerStyle}"
                                                SelectedDate="{Binding SelectedDate}"/>
                                </Grid>
                            </TabItem>
                            <TabItem Header="P.T."
                                     Style="{StaticResource GymbleTabItemStyle}"
                                     MinWidth="87.6">

                            </TabItem>
                            <TabItem Header="운동복"
                                     Style="{StaticResource GymbleTabItemStyle}"
                                     MinWidth="87.6">

                            </TabItem>
                            <TabItem Header="락커"
                                     Style="{StaticResource GymbleTabItemStyle}"
                                     MinWidth="87.6">

                            </TabItem>
                            <TabItem Header="락커"
                                     Style="{StaticResource GymbleTabItemStyle}"
                                     MinWidth="87.6">

                            </TabItem>
                        </TabControl>

                    </StackPanel>


                    <GridSplitter Grid.Column="1"
                                  Width="1" HorizontalAlignment="Center"
                                  Background="{StaticResource SeperatorBorderBrushColor}"/>
                </Grid>
            </StackPanel>
        </common:PopupFrameControl.BodyContent>

        <common:PopupFrameControl.FooterContent>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="취소"
                        Margin="6 0"
                        Style="{StaticResource AddMemberWindowButton}"
                        BorderThickness="1"
                        Background="#FAFAFA"
                        Foreground="#202020"/>
                <Button Content="등록"
                        Style="{StaticResource AddMemberWindowButton}"/>
            </StackPanel>
        </common:PopupFrameControl.FooterContent>
    </common:PopupFrameControl>
</Window>
